# ==============================================================================
# ShieldOps Production Environment Configuration
# ==============================================================================
#
# Production-specific overrides. Start with .env.example as your base, then
# layer these values on top. Only includes settings that MUST differ in
# production — all other defaults from settings.py are production-safe.
#
# SECURITY NOTICE:
#   - Never commit this file with real values.
#   - Use a secret manager (Vault, AWS Secrets Manager, Railway secrets) for
#     all sensitive values (API keys, passwords, tokens).
#   - Rotate JWT_SECRET_KEY immediately after first deploy.
# ==============================================================================

# ── Application ──────────────────────────────────────────────────────────────
SHIELDOPS_ENVIRONMENT=production
SHIELDOPS_DEBUG=false
SHIELDOPS_APP_VERSION=0.1.0

# ── API Server ───────────────────────────────────────────────────────────────
SHIELDOPS_API_HOST=0.0.0.0
SHIELDOPS_API_PORT=8000
SHIELDOPS_CORS_ORIGINS=["https://shieldops.vercel.app","https://app.shieldops.io"]

# ── Database (Neon PostgreSQL recommended for Railway) ───────────────────────
# Use connection pooling in production (PgBouncer or Neon pooler).
SHIELDOPS_DATABASE_URL=postgresql+asyncpg://user:password@host:5432/shieldops?sslmode=require
SHIELDOPS_DATABASE_POOL_SIZE=50

# ── Redis (Upstash recommended for Railway) ──────────────────────────────────
SHIELDOPS_REDIS_URL=rediss://default:password@host:6379

# ── Kafka ────────────────────────────────────────────────────────────────────
# Use a managed Kafka service (Confluent Cloud, Upstash Kafka, Redpanda Cloud).
SHIELDOPS_KAFKA_BROKERS=broker1:9092,broker2:9092
SHIELDOPS_KAFKA_CONSUMER_GROUP=shieldops-agents-prod

# ── Rate Limiting (stricter in production) ───────────────────────────────────
SHIELDOPS_RATE_LIMIT_ENABLED=true
SHIELDOPS_SLIDING_WINDOW_RATE_LIMIT_ENABLED=true
SHIELDOPS_RATE_LIMIT_ADMIN=200
SHIELDOPS_RATE_LIMIT_OPERATOR=100
SHIELDOPS_RATE_LIMIT_VIEWER=50
SHIELDOPS_RATE_LIMIT_DEFAULT=50
SHIELDOPS_RATE_LIMIT_AUTH_LOGIN=5
SHIELDOPS_RATE_LIMIT_AUTH_REGISTER=3

# ── LLM Providers ───────────────────────────────────────────────────────────
# Store these in your secret manager, not in .env files.
SHIELDOPS_ANTHROPIC_API_KEY=sk-ant-...
SHIELDOPS_ANTHROPIC_MODEL=claude-sonnet-4-20250514
SHIELDOPS_OPENAI_API_KEY=sk-...
SHIELDOPS_OPENAI_MODEL=gpt-4o

# ── LLM Router ──────────────────────────────────────────────────────────────
SHIELDOPS_LLM_ROUTING_ENABLED=true
SHIELDOPS_LLM_SIMPLE_MODEL=claude-haiku-4-5-20251001
SHIELDOPS_LLM_MODERATE_MODEL=claude-sonnet-4-20250514
SHIELDOPS_LLM_COMPLEX_MODEL=claude-opus-4-20250514

# ── Agent Configuration (production thresholds) ─────────────────────────────
SHIELDOPS_AGENT_CONFIDENCE_THRESHOLD_AUTO=0.90
SHIELDOPS_AGENT_CONFIDENCE_THRESHOLD_APPROVAL=0.60
SHIELDOPS_AGENT_MAX_INVESTIGATION_TIME_SECONDS=900
SHIELDOPS_AGENT_MAX_REMEDIATION_RETRIES=2
SHIELDOPS_AGENT_GLOBAL_MAX_CONCURRENT=50
SHIELDOPS_AGENT_QUOTA_ENABLED=true

# ── OPA Policy Engine ───────────────────────────────────────────────────────
SHIELDOPS_OPA_ENDPOINT=http://opa:8181

# ── Security / JWT ──────────────────────────────────────────────────────────
# CRITICAL: Generate a strong random secret (e.g., openssl rand -hex 64).
SHIELDOPS_JWT_SECRET_KEY=REPLACE_WITH_64_CHAR_HEX_SECRET
SHIELDOPS_JWT_ALGORITHM=HS256
SHIELDOPS_JWT_EXPIRE_MINUTES=30

# ── OIDC / SSO (recommended for production) ─────────────────────────────────
SHIELDOPS_OIDC_ENABLED=true
SHIELDOPS_OIDC_ISSUER_URL=https://your-idp.example.com
SHIELDOPS_OIDC_CLIENT_ID=shieldops-prod
SHIELDOPS_OIDC_CLIENT_SECRET=...
SHIELDOPS_OIDC_REDIRECT_URI=https://api.shieldops.io/api/v1/auth/oidc/callback

# ── Observability — LangSmith ───────────────────────────────────────────────
SHIELDOPS_LANGSMITH_ENABLED=true
SHIELDOPS_LANGSMITH_API_KEY=ls-...
SHIELDOPS_LANGSMITH_PROJECT=shieldops-production

# ── Observability — OpenTelemetry ────────────────────────────────────────────
SHIELDOPS_TRACING_ENABLED=true
SHIELDOPS_OTEL_EXPORTER_ENDPOINT=https://otel-collector.internal:4317

# ── Stripe Billing ──────────────────────────────────────────────────────────
SHIELDOPS_STRIPE_API_KEY=sk_live_...
SHIELDOPS_STRIPE_WEBHOOK_SECRET=whsec_...
SHIELDOPS_STRIPE_SUCCESS_URL=https://app.shieldops.io/settings?billing=success
SHIELDOPS_STRIPE_CANCEL_URL=https://app.shieldops.io/settings?billing=cancel

# ── Caching (production-tuned) ──────────────────────────────────────────────
SHIELDOPS_CACHE_L1_MAX_SIZE=5000
SHIELDOPS_CACHE_L1_TTL_SECONDS=120
SHIELDOPS_CACHE_L1_ENABLED=true

# ── Feature Flags ────────────────────────────────────────────────────────────
SHIELDOPS_FEATURE_FLAGS_ENABLED=true
SHIELDOPS_FEATURE_FLAGS_SYNC_INTERVAL_SECONDS=60

# ── Health Checks ────────────────────────────────────────────────────────────
SHIELDOPS_HEALTH_CHECK_INTERVAL_SECONDS=30
SHIELDOPS_HEALTH_DEGRADED_THRESHOLD=80.0
SHIELDOPS_HEALTH_UNHEALTHY_THRESHOLD=50.0

# ── Production Safety ───────────────────────────────────────────────────────
SHIELDOPS_PROMOTION_REQUIRE_APPROVAL_FOR_PROD=true
SHIELDOPS_HOT_RELOAD_ENABLED=false
SHIELDOPS_ESCALATION_ENABLED=true
SHIELDOPS_ESCALATION_DEFAULT_TIMEOUT_SECONDS=180

# ── Batch Operations ────────────────────────────────────────────────────────
SHIELDOPS_BATCH_MAX_SIZE=200
SHIELDOPS_BATCH_MAX_PARALLEL=5

# ── Export Engine ────────────────────────────────────────────────────────────
SHIELDOPS_EXPORT_MAX_ROWS=25000
