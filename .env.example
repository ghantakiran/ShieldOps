# ==============================================================================
# ShieldOps Environment Configuration
# ==============================================================================
#
# Copy this file to .env and fill in the values for your environment.
# All variables are prefixed with SHIELDOPS_ (Pydantic BaseSettings convention).
#
# Required variables are marked with [REQUIRED].
# Optional variables have sensible defaults and can be omitted.
#
# For production deployments, see .env.production.example for recommended values.
# ==============================================================================

# ── Application ──────────────────────────────────────────────────────────────
SHIELDOPS_APP_NAME=ShieldOps
SHIELDOPS_APP_VERSION=0.1.0
SHIELDOPS_ENVIRONMENT=development          # development | staging | production
SHIELDOPS_DEBUG=true

# ── API Server ───────────────────────────────────────────────────────────────
SHIELDOPS_API_HOST=0.0.0.0
SHIELDOPS_API_PORT=8000
SHIELDOPS_API_PREFIX=/api/v1
SHIELDOPS_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── Database (PostgreSQL) ────────────────────────────────────────────────── [REQUIRED]
SHIELDOPS_DATABASE_URL=postgresql+asyncpg://shieldops:shieldops@localhost:5432/shieldops
SHIELDOPS_DATABASE_POOL_SIZE=20

# ── Redis ─────────────────────────────────────────────────────────────────── [REQUIRED]
SHIELDOPS_REDIS_URL=redis://localhost:6379/0

# ── Kafka ─────────────────────────────────────────────────────────────────── [REQUIRED]
SHIELDOPS_KAFKA_BROKERS=localhost:9092
SHIELDOPS_KAFKA_CONSUMER_GROUP=shieldops-agents

# ── Rate Limiting ────────────────────────────────────────────────────────────
SHIELDOPS_RATE_LIMIT_ENABLED=true
SHIELDOPS_RATE_LIMIT_WINDOW_SECONDS=60
SHIELDOPS_SLIDING_WINDOW_RATE_LIMIT_ENABLED=false
SHIELDOPS_RATE_LIMIT_ADMIN=300
SHIELDOPS_RATE_LIMIT_OPERATOR=120
SHIELDOPS_RATE_LIMIT_VIEWER=60
SHIELDOPS_RATE_LIMIT_DEFAULT=60
SHIELDOPS_RATE_LIMIT_AUTH_LOGIN=10
SHIELDOPS_RATE_LIMIT_AUTH_REGISTER=5

# ── LLM Providers ───────────────────────────────────────────────────────── [REQUIRED]
SHIELDOPS_ANTHROPIC_API_KEY=sk-ant-...
SHIELDOPS_ANTHROPIC_MODEL=claude-sonnet-4-20250514
SHIELDOPS_OPENAI_API_KEY=sk-...
SHIELDOPS_OPENAI_MODEL=gpt-4o

# ── LLM Router (Phase 12) ───────────────────────────────────────────────────
SHIELDOPS_LLM_ROUTING_ENABLED=false
SHIELDOPS_LLM_SIMPLE_MODEL=claude-haiku-4-5-20251001
SHIELDOPS_LLM_MODERATE_MODEL=claude-sonnet-4-20250514
SHIELDOPS_LLM_COMPLEX_MODEL=claude-opus-4-20250514

# ── RAG Knowledge Store (Phase 12) ──────────────────────────────────────────
SHIELDOPS_RAG_ENABLED=false
SHIELDOPS_RAG_EMBEDDING_MODEL=text-embedding-3-small

# ── Agent Configuration ─────────────────────────────────────────────────────
SHIELDOPS_AGENT_CONFIDENCE_THRESHOLD_AUTO=0.85
SHIELDOPS_AGENT_CONFIDENCE_THRESHOLD_APPROVAL=0.50
SHIELDOPS_AGENT_MAX_INVESTIGATION_TIME_SECONDS=600
SHIELDOPS_AGENT_MAX_REMEDIATION_RETRIES=3
SHIELDOPS_AGENT_GLOBAL_MAX_CONCURRENT=20
SHIELDOPS_AGENT_QUOTA_ENABLED=true

# ── OPA Policy Engine ───────────────────────────────────────────────────── [REQUIRED]
SHIELDOPS_OPA_ENDPOINT=http://localhost:8181

# ── Security / JWT ──────────────────────────────────────────────────────── [REQUIRED]
SHIELDOPS_JWT_SECRET_KEY=change-me-in-production
SHIELDOPS_JWT_ALGORITHM=HS256
SHIELDOPS_JWT_EXPIRE_MINUTES=60

# ── OIDC / SSO ──────────────────────────────────────────────────────────────
SHIELDOPS_OIDC_ENABLED=false
SHIELDOPS_OIDC_ISSUER_URL=
SHIELDOPS_OIDC_CLIENT_ID=
SHIELDOPS_OIDC_CLIENT_SECRET=
SHIELDOPS_OIDC_REDIRECT_URI=http://localhost:8000/api/v1/auth/oidc/callback
SHIELDOPS_OIDC_SCOPES=openid email profile

# ── Observability — LangSmith ───────────────────────────────────────────────
SHIELDOPS_LANGSMITH_API_KEY=ls-...
SHIELDOPS_LANGSMITH_PROJECT=shieldops
SHIELDOPS_LANGSMITH_ENABLED=false

# ── Observability — OpenTelemetry ────────────────────────────────────────────
SHIELDOPS_OTEL_EXPORTER_ENDPOINT=http://localhost:4317
SHIELDOPS_OTEL_ENDPOINT=http://localhost:4317
SHIELDOPS_TRACING_ENABLED=false

# ── Observability — Prometheus ───────────────────────────────────────────────
SHIELDOPS_PROMETHEUS_URL=http://localhost:9090

# ── Observability — Splunk ───────────────────────────────────────────────────
SHIELDOPS_SPLUNK_URL=
SHIELDOPS_SPLUNK_TOKEN=
SHIELDOPS_SPLUNK_INDEX=main
SHIELDOPS_SPLUNK_VERIFY_SSL=true

# ── Observability — Datadog ──────────────────────────────────────────────────
SHIELDOPS_DATADOG_API_KEY=
SHIELDOPS_DATADOG_APP_KEY=
SHIELDOPS_DATADOG_SITE=datadoghq.com

# ── Observability — Jaeger ───────────────────────────────────────────────────
SHIELDOPS_JAEGER_URL=

# ── Observability — New Relic ────────────────────────────────────────────────
SHIELDOPS_NEWRELIC_API_KEY=
SHIELDOPS_NEWRELIC_ACCOUNT_ID=

# ── Observability — Elastic / OpenSearch ─────────────────────────────────────
SHIELDOPS_ELASTIC_URL=
SHIELDOPS_ELASTIC_API_KEY=

# ── Slack Integration ────────────────────────────────────────────────────────
SHIELDOPS_SLACK_BOT_TOKEN=xoxb-...
SHIELDOPS_SLACK_SIGNING_SECRET=
SHIELDOPS_SLACK_APPROVAL_CHANNEL=#shieldops-approvals

# ── PagerDuty ────────────────────────────────────────────────────────────────
SHIELDOPS_PAGERDUTY_ROUTING_KEY=

# ── Webhooks ─────────────────────────────────────────────────────────────────
SHIELDOPS_WEBHOOK_URL=
SHIELDOPS_WEBHOOK_SECRET=
SHIELDOPS_WEBHOOK_TIMEOUT=10.0

# ── Email / SMTP ─────────────────────────────────────────────────────────────
SHIELDOPS_SMTP_HOST=
SHIELDOPS_SMTP_PORT=587
SHIELDOPS_SMTP_USERNAME=
SHIELDOPS_SMTP_PASSWORD=
SHIELDOPS_SMTP_USE_TLS=true
SHIELDOPS_SMTP_FROM_ADDRESS=shieldops@localhost
# SHIELDOPS_SMTP_TO_ADDRESSES=["admin@example.com"]

# ── AWS ──────────────────────────────────────────────────────────────────────
SHIELDOPS_AWS_REGION=
SHIELDOPS_AWS_ACCESS_KEY_ID=
SHIELDOPS_AWS_SECRET_ACCESS_KEY=
SHIELDOPS_CLOUDWATCH_LOG_GROUP=

# ── GCP ──────────────────────────────────────────────────────────────────────
SHIELDOPS_GCP_PROJECT_ID=
SHIELDOPS_GCP_REGION=us-central1
SHIELDOPS_GCP_BILLING_DATASET=billing_export
SHIELDOPS_GCP_BILLING_TABLE=gcp_billing_export_v1
SHIELDOPS_GCP_SECRET_MANAGER_ENABLED=false

# ── Azure ────────────────────────────────────────────────────────────────────
SHIELDOPS_AZURE_SUBSCRIPTION_ID=
SHIELDOPS_AZURE_RESOURCE_GROUP=
SHIELDOPS_AZURE_LOCATION=eastus
SHIELDOPS_AZURE_BILLING_ENABLED=false
SHIELDOPS_AZURE_KEYVAULT_URL=

# ── Stripe Billing ──────────────────────────────────────────────────────────
SHIELDOPS_STRIPE_API_KEY=
SHIELDOPS_STRIPE_WEBHOOK_SECRET=
SHIELDOPS_STRIPE_SUCCESS_URL=http://localhost:5173/settings?billing=success
SHIELDOPS_STRIPE_CANCEL_URL=http://localhost:5173/settings?billing=cancel

# ── Vulnerability / Security Scanners ────────────────────────────────────────
SHIELDOPS_NVD_API_KEY=
SHIELDOPS_TRIVY_SERVER_URL=
SHIELDOPS_TRIVY_TIMEOUT=300
SHIELDOPS_GITLEAKS_PATH=gitleaks
SHIELDOPS_OSV_SCANNER_PATH=osv-scanner
SHIELDOPS_CHECKOV_PATH=checkov
SHIELDOPS_IAC_SCANNER_ENABLED=false
SHIELDOPS_GIT_SCANNER_ENABLED=false
SHIELDOPS_K8S_SCANNER_ENABLED=false
SHIELDOPS_NETWORK_SCANNER_ENABLED=false
SHIELDOPS_GITHUB_ADVISORY_TOKEN=
SHIELDOPS_GHSA_ENABLED=false
SHIELDOPS_OS_ADVISORY_FEEDS_ENABLED=false
SHIELDOPS_SBOM_ENABLED=false
SHIELDOPS_SYFT_PATH=syft

# ── Threat Intelligence ─────────────────────────────────────────────────────
SHIELDOPS_MITRE_ATTACK_ENABLED=false
SHIELDOPS_EPSS_ENABLED=false

# ── HashiCorp Vault ──────────────────────────────────────────────────────────
SHIELDOPS_VAULT_ADDR=
SHIELDOPS_VAULT_TOKEN=
SHIELDOPS_VAULT_MOUNT_POINT=secret
SHIELDOPS_VAULT_NAMESPACE=

# ── Linux SSH Connector ─────────────────────────────────────────────────────
SHIELDOPS_LINUX_HOST=
SHIELDOPS_LINUX_USERNAME=
SHIELDOPS_LINUX_PRIVATE_KEY_PATH=

# ── Windows WinRM Connector ─────────────────────────────────────────────────
SHIELDOPS_WINDOWS_HOST=
SHIELDOPS_WINDOWS_USERNAME=
SHIELDOPS_WINDOWS_PASSWORD=
SHIELDOPS_WINDOWS_USE_SSL=true
SHIELDOPS_WINDOWS_PORT=5986

# ── Chat Sessions ────────────────────────────────────────────────────────────
SHIELDOPS_CHAT_SESSION_TTL_SECONDS=86400
SHIELDOPS_CHAT_MAX_MESSAGES_PER_SESSION=50

# ── Prediction Agent (Phase 12) ─────────────────────────────────────────────
SHIELDOPS_PREDICTION_CONFIDENCE_THRESHOLD=0.75
SHIELDOPS_PREDICTION_SCHEDULE_MINUTES=30

# ── SLO Monitoring (Phase 13) ───────────────────────────────────────────────
SHIELDOPS_SLO_BURN_RATE_THRESHOLD=2.0

# ── Caching (Phase 14) ──────────────────────────────────────────────────────
SHIELDOPS_CACHE_L1_MAX_SIZE=1000
SHIELDOPS_CACHE_L1_TTL_SECONDS=60
SHIELDOPS_CACHE_L1_ENABLED=true

# ── Feature Flags (Phase 14) ────────────────────────────────────────────────
SHIELDOPS_FEATURE_FLAGS_ENABLED=true
SHIELDOPS_FEATURE_FLAGS_SYNC_INTERVAL_SECONDS=30

# ── Health Checks (Phase 14) ────────────────────────────────────────────────
SHIELDOPS_HEALTH_HISTORY_SIZE=100
SHIELDOPS_HEALTH_CHECK_INTERVAL_SECONDS=60
SHIELDOPS_HEALTH_DEGRADED_THRESHOLD=70.0
SHIELDOPS_HEALTH_UNHEALTHY_THRESHOLD=40.0

# ==============================================================================
# Note: Many Phase 15-23+ feature flags have sensible defaults (enabled=true)
# and do not need to be set unless you want to override them. See
# src/shieldops/config/settings.py for the full list of configuration options.
# ==============================================================================
